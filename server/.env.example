# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Model slug. Default uses DeepSeek V3.2 (free tier on OpenRouter).
# Other free options: "qwen/qwen-2.5-72b-instruct:free", "z-ai/glm-4.5-air:free",
# "moonshotai/kimi-k2:free", "google/gemini-2.0-flash-exp:free"
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.2-exp:free

# Optional. OpenRouter recommends setting these for app attribution.
APP_REFERER=http://localhost:3000
APP_TITLE=DigitalTwin OS

# Backend port
PORT=3001
